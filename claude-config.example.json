# Claude Desktop Configuration
# Copy this to your Claude Desktop config file
#
# ⚠️ 注意：请替换以下路径为你自己的实际路径
# Windows 示例: C:\\path\\to\\fnpackup\\projects
# macOS/Linux 示例: /path/to/fnpackup/projects

{
  "mcpServers": {
    "fnpackup": {
      "command": "node",
      "args": ["/path/to/fnpackup-mcp-server/dist/index.js"],
      "env": {
        "PROJECTS_DIR": "/path/to/fnpackup/projects",
        "FNPACKUP_SERVICE_URL": "http://localhost:1069"
      }
    }
  }
}
