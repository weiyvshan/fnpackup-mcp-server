    "adm-zip": "^0.5.10",
    "fs-extra": "^11.2.0",
    "chokidar": "^3.5.3",
    "yaml": "^2.3.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.2"
  }
}
