{
  "name": "mcp-fpk-packager",
  "version": "1.0.0",
  "description": "MCP server for packaging fpk applications",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "fnpackup",
    "fpk",
    "packaging"
  ],
